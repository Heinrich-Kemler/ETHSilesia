# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
artifacts*

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# hardhat build output — regenerated on compile, not source-of-truth
/artifacts
/cache
/typechain-types

# local/private deployment records (e.g., addresses tied to sensitive networks)
deployments.local.json
deployments.private.json

# macOS recursive
**/.DS_Store

