# Feature flag: set to "true" to re-enable Grok/OpenAI calls from
# /api/ai/explain and /api/ai/chat. Defaults to false to save credits.
AI_ENABLED=false

# Use XAI_API_KEY for Grok (recommended). OPENAI_API_KEY is kept as fallback.
XAI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.x.ai/v1
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
NEXT_PUBLIC_PRIVY_APP_ID=
# Privy dashboard "JWT verification key" (SPKI public key).
PRIVY_JWT_VERIFICATION_KEY=
# Random secret used to sign secure HTTP-only app session cookies.
SESSION_SIGNING_SECRET=
PRIVATE_KEY=
BASE_SEPOLIA_RPC=https://sepolia.base.org
INTERNAL_API_KEY=
# Optional override; falls back to deployments.json for baseSepolia.
SKARBNIK_BADGES_ADDRESS=

# Google Gemini — used server-side for RAG embeddings in /api/ai/chat.
# Required when AI_ENABLED=true.
GEMINI_API_KEY=

# Optional but recommended
BASESCAN_API_KEY=
BADGE_METADATA_BASE_URI=ipfs://QmSkarbnikBadgeMetadataPlaceholder/
OPENAI_MODEL=grok-4-1-fast-non-reasoning

# Vercel Cron — secures /api/alerts/fetch endpoint.
# Set this in Vercel dashboard → Environment Variables.
CRON_SECRET=

# Optional frontend vars (if your UI uses Supabase client-side)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
